---
import Layout from '../../layouts/Layout.astro'
import Card from '../../components/common/Card.astro'
import { getAllEcosistemas } from '../../utils/collections'

const ecosistemas = await getAllEcosistemas()
---

<Layout titulo="Ecosistemas" activeTab="ecosistemas">
  <div class="px-4 pt-6">
    <h1 class="text-xl font-medium text-stone-100 mb-1">Ecosistemas</h1>
    <p class="text-stone-400 text-sm mb-6">Galicia · {ecosistemas.length} ecosistemas</p>

    <div class="flex flex-col gap-3">
      {ecosistemas.map(eco => (
        <Card
          href={`/ecosistemas/${eco.id}`}
          title={eco.data.nome}
          subtitle={eco.data.zona}
          description={eco.data.resumo}
        />
      ))}
    </div>
  </div>
</Layout>