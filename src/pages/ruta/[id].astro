---
import { getCollection, getEntry, render } from 'astro:content'
import Layout from '../../layouts/Layout.astro'

export async function getStaticPaths() {
  const rutas = await getCollection('rutas')
  return rutas.map(ruta => ({
    params: { id: ruta.id },
    props: { ruta }
  }))
}

const { ruta } = Astro.props
const ecosistema = await getEntry(ruta.data.ecosistema)
const { Content } = await render(ruta)
---

<Layout titulo={ruta.data.titulo}>

  <div class="bg-stone-900 px-4 pt-6 pb-4">
    <a href="/rutas" class="text-green-500 text-sm mb-3 flex items-center gap-1">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Todas as rutas
    </a>
    <h1 class="text-2xl font-medium text-stone-100">{ruta.data.titulo}</h1>
    {ruta.data.subtitulo && (
      <p class="text-stone-400 text-sm mt-1">{ruta.data.subtitulo}</p>
    )}
    <div class="flex gap-2 mt-3 flex-wrap">
      <span class="bg-stone-800 text-stone-300 text-xs px-3 py-1 rounded-full">
        {ruta.data.tipo}
      </span>
      <span class="bg-stone-800 text-stone-300 text-xs px-3 py-1 rounded-full">
        {ruta.data.dificultade}
      </span>
      <span class="bg-stone-800 text-stone-300 text-xs px-3 py-1 rounded-full">
        {ruta.data.provincia}
      </span>
    </div>
  </div>

  <div
    id="mapa"
    class="w-full h-96 bg-stone-800 relative z-0"
    data-lat={ruta.data.coordenadasInicio.lat}
    data-lng={ruta.data.coordenadasInicio.lng}
  ></div>

  <div class="grid grid-cols-3 gap-px bg-stone-800 border-y border-stone-800">
    <div class="bg-stone-950 px-4 py-3 text-center">
      <div class="text-lg font-medium text-stone-100">{ruta.data.distancia} km</div>
      <div class="text-xs text-stone-400 mt-0.5">Distancia</div>
    </div>
    <div class="bg-stone-950 px-4 py-3 text-center">
      <div class="text-lg font-medium text-stone-100">↑ {ruta.data.desnivel} m</div>
      <div class="text-xs text-stone-400 mt-0.5">Desnivel</div>
    </div>
    <div class="bg-stone-950 px-4 py-3 text-center">
      <div class="text-lg font-medium text-stone-100">{ruta.data.duracion}</div>
      <div class="text-xs text-stone-400 mt-0.5">Duración</div>
    </div>
  </div>

  {ecosistema && (
    <a href={`/ecosistemas/${ecosistema.id}`}
       class="mx-4 mt-4 flex items-center gap-3 bg-stone-900 border border-stone-800 rounded-xl p-3 hover:border-green-800 transition-colors">
      <div class="w-2 h-2 rounded-full bg-green-500 shrink-0"></div>
      <div>
        <div class="text-xs text-stone-400">Ecosistema</div>
        <div class="text-sm text-stone-200 font-medium">{ecosistema.data.nome}</div>
        <div class="text-xs text-stone-400">{ecosistema.data.zona}</div>
      </div>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-stone-600 ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </a>
  )}

  <div class="px-4 py-6 prose prose-invert prose-sm max-w-none
              prose-headings:text-stone-200 prose-headings:font-medium
              prose-p:text-stone-400 prose-p:leading-relaxed
              prose-strong:text-stone-300
              prose-em:text-stone-400">
    <Content />
  </div>

</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script define:vars={{ gpxFile: ruta.data.gpxFile, lat: ruta.data.coordenadasInicio.lat, lng: ruta.data.coordenadasInicio.lng }}>

document.addEventListener('DOMContentLoaded', async () => {
  const L = window.L

  const mapa = L.map('mapa', {
    zoomControl: false,
    attributionControl: true
  }).setView([lat, lng], 14)

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap'
  }).addTo(mapa)

  L.control.zoom({ position: 'bottomright' }).addTo(mapa)

  if (!gpxFile) return

  try {
    const res = await fetch(`/data/rutas/${gpxFile}`)
    const data = await res.json()

    if (data.track && data.track.length > 0) {
      const trackCoords = data.track.map(p => [p[0], p[1]])
      L.polyline(trackCoords, {
        color: '#4caf50',
        weight: 3,
        opacity: 0.9
      }).addTo(mapa)
      mapa.fitBounds(L.polyline(trackCoords).getBounds(), { padding: [20, 20] })
    }

    if (data.waypoints) {
      data.waypoints.forEach(w => {
        const icono = L.divIcon({
          className: '',
          html: `<div style="width:24px;height:24px;background:#1a2e1a;border:2px solid #4caf50;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;color:#4caf50;font-family:system-ui,sans-serif;box-shadow:0 2px 8px rgba(0,0,0,0.4)">${w.num}</div>`,
          iconSize: [24, 24],
          iconAnchor: [12, 12]
        })
        L.marker([w.lat, w.lng], { icon: icono })
          .addTo(mapa)
          .bindPopup(`
            <div style="font-family:system-ui,sans-serif;min-width:180px">
              <div style="font-weight:600;font-size:13px;margin-bottom:4px;color:#1a2e1a">
                ${w.num}. ${w.nome}
              </div>
              <div style="font-size:11px;color:#555;margin-bottom:4px">${w.km} km</div>
              <div style="font-size:12px;color:#333;line-height:1.4">${w.nota}</div>
            </div>
          `, { maxWidth: 220 })
      })
    }

  } catch(e) {
    console.error('Error cargando datos de ruta:', e)
  }

  const iconoGeo = L.divIcon({
    className: '',
    html: `<div style="width:14px;height:14px;background:#2196f3;border:2px solid #fff;border-radius:50%;box-shadow:0 0 0 4px rgba(33,150,243,0.3)"></div>`,
    iconSize: [14, 14],
    iconAnchor: [7, 7]
  })

  let marcadorGeo = null
  if (navigator.geolocation) {
    navigator.geolocation.watchPosition(pos => {
      const { latitude, longitude } = pos.coords
      if (marcadorGeo) {
        marcadorGeo.setLatLng([latitude, longitude])
      } else {
        marcadorGeo = L.marker([latitude, longitude], { icon: iconoGeo }).addTo(mapa)
      }
    }, null, { enableHighAccuracy: true, maximumAge: 5000 })
  }
})
</script>