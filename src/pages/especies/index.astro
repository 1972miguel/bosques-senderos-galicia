---
import Layout from '../../layouts/Layout.astro'
import Card from '../../components/common/Card.astro'
import { getAllEspecies, getSpeciesByType } from '../../utils/collections'

const speciesByType = await getSpeciesByType()

const typeColor = (type: string) => {
  const map: Record<string, any> = {
    'flora': 'green',
    'fauna': 'blue',
    'fungo': 'orange',
    'liquen': 'stone'
  }
  return map[type] || 'stone'
}

const conservationColor = (status: string) => {
  const map: Record<string, any> = {
    'LC': 'green',
    'NT': 'yellow',
    'VU': 'orange',
    'EN': 'red',
    'CR': 'red'
  }
  return map[status] || 'stone'
}

const totalSpecies = Object.values(speciesByType).reduce((acc, arr) => acc + arr.length, 0)
---

<Layout titulo="Especies" activeTab="especies">
  <div class="px-4 pt-6">
    <h1 class="text-xl font-medium text-stone-100 mb-1">Especies</h1>
    <p class="text-stone-400 text-sm mb-6">Galicia · {totalSpecies} especies</p>

    {Object.entries(speciesByType).map(([type, species]) => {
      if (species.length === 0) return null
      
      const typeLabel = type.charAt(0).toUpperCase() + type.slice(1)
      
      return (
        <section class="mb-6">
          <h2 class="text-xs font-medium text-stone-400 uppercase tracking-wide mb-3">{typeLabel}</h2>
          <div class="flex flex-col gap-2">
            {species.map(e => (
              <Card
                href={`/especies/${e.id}`}
                title={e.data.nomeComun}
                subtitle={e.data.nomeCientifico}
                metadata={[
                  { label: 'Familia', value: e.data.familia }
                ]}
                badges={[
                  { label: type, color: typeColor(type) },
                  ...(e.data.conservacion ? [{ label: e.data.conservacion, color: conservationColor(e.data.conservacion) }] : [])
                ]}
              />
            ))}
          </div>
        </section>
      )
    })}
  </div>
</Layout>