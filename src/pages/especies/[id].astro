---
import { getCollection, getEntry, render } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import Card from '../../components/common/Card.astro'
import { getSpecieIds } from '../../utils/collections'
import { CONSERVATION_LABELS, CONSERVATION_CLASSES, SPECIES_TYPE_CLASSES } from '../../types'

export async function getStaticPaths() {
  const specieIds = await getSpecieIds()
  const especies = await getCollection('especies')
  
  return especies.map(especie => ({
    params: { id: especie.id },
    props: { especie }
  }))
}

const { especie } = Astro.props
const { Content } = await render(especie)

// ✅ FIX: Cargar ecosistemas en paralelo ANTES del template
let ecosistemasData: Array<{ id: string; data: any }> = []
if (especie.data.ecosistemas && especie.data.ecosistemas.length > 0) {
  ecosistemasData = await Promise.all(
    especie.data.ecosistemas.map(ref => getEntry(ref))
  )
}
---

<Layout titulo={especie.data.nomeComun} activeTab="especies">

  <!-- Cabecera -->
  <div class="bg-stone-900 px-4 pt-6 pb-5">
    <a href="/especies" class="text-green-500 text-sm mb-3 flex items-center gap-1">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Especies
    </a>
    <h1 class="text-2xl font-medium text-stone-100">{especie.data.nomeComun}</h1>
    <p class="text-stone-400 text-sm italic mt-1">{especie.data.nomeCientifico}</p>
    <p class="text-stone-400 text-xs mt-1">{especie.data.familia}</p>

    <div class="flex gap-2 mt-3 flex-wrap items-center">
      <span class={`text-xs px-3 py-1 rounded-full border
        ${SPECIES_TYPE_CLASSES[especie.data.tipo]}`}>
        {especie.data.tipo}
      </span>
      {especie.data.conservacion && (
        <span class={`text-xs px-3 py-1 rounded-full border ${CONSERVATION_CLASSES[especie.data.conservacion]}`}>
          {especie.data.conservacion} · {CONSERVATION_LABELS[especie.data.conservacion]}
        </span>
      )}
    </div>
  </div>

  <!-- Ecosistemas vinculados -->
  {ecosistemasData && ecosistemasData.length > 0 && (
    <div class="px-4 mt-4">
      <h2 class="text-xs font-medium text-stone-400 uppercase tracking-wide mb-2">Ecosistemas</h2>
      <div class="flex flex-col gap-2">
        {ecosistemasData.map(eco => (
          <Card
            href={`/ecosistemas/${eco.id}`}
            title={eco.data.nome}
            subtitle={eco.data.zona}
          />
        ))}
      </div>
    </div>
  )}

  <!-- Contenido MDX -->
  <div class="px-4 py-6 prose prose-invert prose-sm max-w-none
              prose-headings:text-stone-200 prose-headings:font-medium
              prose-p:text-stone-400 prose-p:leading-relaxed
              prose-strong:text-stone-300
              prose-em:text-stone-400">
    <Content />
  </div>

</Layout>