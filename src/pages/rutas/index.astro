---
import Layout from '../../layouts/Layout.astro'
import Card from '../../components/common/Card.astro'
import { getPublishedRoutes } from '../../utils/collections'

const rutas = await getPublishedRoutes()

const difficultyColor = (difficulty: string) => {
  const colorMap: Record<string, any> = {
    fácil: 'green',
    moderada: 'yellow',
    difícil: 'red'
  }
  return colorMap[difficulty] || 'stone'
}
---

<Layout titulo="Rutas" activeTab="rutas">
  <div class="px-4 pt-6">
    <h1 class="text-xl font-medium text-stone-100 mb-1">Rutas</h1>
    <p class="text-stone-400 text-sm mb-6">Galicia · {rutas.length} sendeiros</p>

    <div class="flex flex-col gap-3">
      {rutas.map(ruta => (
        <Card
          href={`/ruta/${ruta.id}`}
          title={ruta.data.titulo}
          subtitle={ruta.data.provincia}
          badges={[
            { label: ruta.data.dificultade, color: difficultyColor(ruta.data.dificultade) }
          ]}
          metadata={[
            { label: 'Distancia', value: `${ruta.data.distancia} km` },
            { label: 'Desnivel', value: `↑ ${ruta.data.desnivel} m` },
            { label: 'Duración', value: ruta.data.duracion }
          ]}
        />
      ))}
    </div>
  </div>
</Layout>