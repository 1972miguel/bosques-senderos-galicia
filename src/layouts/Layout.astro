
---
import '../styles/global.css'
import Navigation from '../components/common/Navigation.astro'

interface Props {
  titulo: string
  descricion?: string
  activeTab?: 'inicio' | 'rutas' | 'ecosistemas' | 'especies'
}

const { 
  titulo, 
  descricion = 'Rutas con ficha ecolóxica do ecosistema galego',
  activeTab 
} = Astro.props
---

<!doctype html>
<html lang="gl" class="bg-black"> <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="description" content={descricion} />
    
    <!-- Open Graph / Social Media -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={titulo + ' · Sendeiros de Galicia'} />
    <meta property="og:description" content={descricion} />
    <meta property="og:image" content="/favicon.svg" />
    <meta property="og:site_name" content="Sendeiros de Galicia" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titulo + ' · Sendeiros de Galicia'} />
    <meta name="twitter:description" content={descricion} />
    <meta name="twitter:image" content="/favicon.svg" />
    
    <!-- Additional Meta -->
    <meta name="keywords" content="rutas, senderismo, ecosistema, Galicia, biodiversidad, especies" />
    <meta name="author" content="Sendeiros de Galicia" />
    <meta name="language" content="gl" />
    <meta name="revisit-after" content="7 days" />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://senderosegalizia.gal" />
    <meta name="theme-color" content="#1a2e1a" />

    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <title>{titulo} · Sendeiros de Galicia</title>
  </head>

  <body class="bg-stone-950 text-stone-100 min-h-screen flex flex-col max-w-2xl mx-auto shadow-[0_0_50px_rgba(0,0,0,0.5)] border-x border-stone-900">

    <main class="flex-1 pb-24"> <slot />
    </main>

    <!-- ✅ COMPONENTE REUTILIZABLE (Fase 1) -->
    <Navigation activeTab={activeTab} />
  </body>
</html>