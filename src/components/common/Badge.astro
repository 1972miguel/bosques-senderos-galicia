---
/**
 * Componente Badge/Tag reutilizable
 * @file src/components/common/Badge.astro
 * 
 * Badge temático para estados, categorías, etc
 * 
 * Uso:
 * <Badge label="moderada" color="stone" />
 * <Badge label="EN" color="red" />
 */

import type { BadgeColor } from '../../types'

interface Props {
  label: string
  color?: BadgeColor
}

const { label, color = 'stone' } = Astro.props

const colorClasses: Record<BadgeColor, string> = {
  'stone': 'bg-stone-800 text-stone-300 border-stone-700',
  'green': 'bg-green-950 text-green-400 border-green-900',
  'yellow': 'bg-yellow-950 text-yellow-400 border-yellow-900',
  'orange': 'bg-orange-950 text-orange-400 border-orange-900',
  'red': 'bg-red-950 text-red-400 border-red-900',
  'blue': 'bg-blue-950 text-blue-400 border-blue-900'
}
---

<span class={`text-xs px-2.5 py-1 rounded-full border font-medium whitespace-nowrap ${colorClasses[color]}`}>
  {label}
</span>
