# Apache configuration for Senderos e Bosques de Galicia
# Cache headers and compression settings

# Enable GZIP compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/xhtml+xml
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE image/svg+xml
  
  # Disable for old browsers
  BrowserMatch ^Mozilla/4 no-gzip
  BrowserMatch ^Mozilla/4\.0[678] no-gzip
  BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
  BrowserMatch \bMSI[E] !no-gzip !gzip-only-text/html
</IfModule>

# Set Expires headers for better caching
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Default: 2 days
  ExpiresDefault "access plus 2 days"
  
  # HTML files: 1 hour (content changes frequently)
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType application/xhtml+xml "access plus 1 hour"
  
  # CSS: 1 year with versioning
  ExpiresByType text/css "access plus 1 year"
  
  # JavaScript: 1 year with versioning
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/x-javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  
  # Images: 1 year
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  
  # Fonts: 1 year
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  
  # JSON: 1 hour
  ExpiresByType application/json "access plus 1 hour"
  
  # Manifest: 1 hour
  ExpiresByType application/manifest+json "access plus 1 hour"
  ExpiresByType application/webmanifest "access plus 1 hour"
</IfModule>

# Use ETag for better cache validation
<IfModule mod_headers.c>
  # Add ETag header
  Header append Cache-Control "public"
  
  # Security headers
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  
  # Preload critical resources
  Header set Link "</css/global.css>; rel=preload; as=style"
  Header set Link "</favico.svg>; rel=preload; as=image"
</IfModule>

# Gzip compression variable
<IfModule mod_setenvif.c>
  SetEnvIfNoCase Request_URI \
    \.(?:gif|jpe?g|png|rar|zip|exe|mov|avi|mp3|mp4|mkv|svg|woff|woff2)$ no-gzip dont-vary
</IfModule>

# Add Vary header for cached content
<IfModule mod_headers.c>
  Header append Vary Accept-Encoding
  Header append Vary Accept-Language
</IfModule>

# Enable keep-alive connections
<IfModule mod_headers.c>
  Header set Connection keep-alive
</IfModule>

# Disable directory listing
<FilesMatch "^\.">
  Deny from all
</FilesMatch>

Options -Indexes
